---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroScene from "../components/three/HeroScene";
---

<BaseLayout title="Contact — weihung">
  <div class="fixed inset-0 z-0 pointer-events-none">
    <HeroScene client:only="react" />
  </div>

  <section class="min-h-screen flex flex-col pt-32 pb-12 px-8 sm:px-12 relative z-10">
    <p class="font-heading text-xs uppercase tracking-[0.3em] text-white/50 mb-8 contact-fade">
      Contact
    </p>
    <h1 class="contact-title font-heading font-medium text-white leading-[0.95] mb-10 sm:mb-16" style="font-size: clamp(2.5rem, 8vw, 7rem); letter-spacing: -0.04em;">
      <span class="contact-line"><span class="contact-word">有想法？</span></span>
      <br />
      <span class="contact-line"><span class="contact-word">聊聊吧。</span></span>
    </h1>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4 max-w-3xl contact-fade">
      <a href="mailto:drum831@gmail.com" class="contact-card group">
        <div class="contact-card-glow"></div>
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/40 group-hover:text-white transition-colors">
              <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/20 group-hover:text-white transition-all group-hover:translate-x-1 group-hover:-translate-y-1">
              <path d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </div>
          <p class="font-heading text-xs uppercase tracking-wider text-white/40 group-hover:text-white/60 transition-colors mb-1">Email</p>
          <p class="font-heading text-sm sm:text-lg text-white/80 group-hover:text-white transition-colors hidden sm:block">drum831@gmail.com</p>
        </div>
      </a>
      <a href="https://github.com/weihung0831" target="_blank" rel="noopener noreferrer" class="contact-card group">
        <div class="contact-card-glow"></div>
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40 group-hover:text-white transition-colors">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" />
            </svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/20 group-hover:text-white transition-all group-hover:translate-x-1 group-hover:-translate-y-1">
              <path d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </div>
          <p class="font-heading text-xs uppercase tracking-wider text-white/40 group-hover:text-white/60 transition-colors mb-1">GitHub</p>
          <p class="font-heading text-sm sm:text-lg text-white/80 group-hover:text-white transition-colors hidden sm:block">@weihung0831</p>
        </div>
      </a>
      <a href="https://line.me/ti/p/pW7V4Aku5N" target="_blank" rel="noopener noreferrer" class="contact-card group">
        <div class="contact-card-glow"></div>
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-[#06C755]">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314" />
            </svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/20 group-hover:text-white transition-all group-hover:translate-x-1 group-hover:-translate-y-1">
              <path d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </div>
          <p class="font-heading text-xs uppercase tracking-wider text-white/40 group-hover:text-white/60 transition-colors mb-1">Line</p>
          <p class="font-heading text-sm sm:text-lg text-white/80 group-hover:text-white transition-colors hidden sm:block">加好友</p>
        </div>
      </a>
    </div>

    <!-- Page Nav -->
    <div class="mt-auto border-t border-white/[0.06] pt-12 contact-fade">
      <a href="/about/" class="group inline-flex items-center gap-3 font-heading text-sm uppercase tracking-wider text-white/50 hover:text-white transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform group-hover:-translate-x-1">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        View About
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-line {
    display: block;
    overflow: hidden;
  }

  .contact-word {
    display: inline-block;
    transform: translateY(120%);
  }

  .contact-fade {
    opacity: 0;
    transform: translateY(24px);
  }

  .contact-card {
    position: relative;
    padding: 1.5rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    background: rgba(255,255,255,0.03);
    overflow: hidden;
    transition: border-color 0.4s ease, transform 0.3s ease;
  }

  .contact-card:hover {
    border-color: rgba(255,255,255,0.25);
    transform: translateY(-3px);
  }

  .contact-card-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.06) 0%, transparent 70%);
  }

  .contact-card:hover .contact-card-glow {
    opacity: 1;
  }
</style>

<script>
  import { gsap } from "gsap";

  function initContact() {
    gsap.to(".contact-word", {
      y: 0,
      duration: 1.2,
      ease: "power4.out",
      stagger: 0.15,
      delay: 0.2,
    });

    gsap.to(".contact-fade", {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: "power3.out",
      stagger: 0.12,
      delay: 0.6,
    });
  }

  document.addEventListener("astro:page-load", initContact);
</script>
