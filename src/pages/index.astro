---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroScene from "../components/three/HeroScene";
---

<BaseLayout title="weihung — 全端工程師">
  <section class="relative min-h-screen flex flex-col pt-32 pb-12 px-8 sm:px-12">
    <HeroScene client:only="react" />
    <div class="relative z-10">
      <p id="hero-label" class="font-heading text-xs uppercase tracking-[0.3em] text-white/50 mb-6 opacity-0">
        Freelance Full-Stack Developer
      </p>
      <h1 id="hero-heading" class="font-heading font-medium text-white leading-[0.9]" style="font-size: clamp(3rem, 10vw, 9rem); letter-spacing: -0.04em;">
        <span class="hero-line block overflow-hidden"><span class="hero-word inline-block">從想法到上線</span></span>
        <span class="hero-line block overflow-hidden"><span class="hero-word inline-block">一手搞定。</span></span>
      </h1>
      <p id="hero-desc" class="text-sm text-white/50 max-w-xs leading-relaxed mt-12 opacity-0">
        擅長用 React、Vue、Next.js、Laravel、Python 打造完整的網站和應用程式。
      </p>
    </div>
    <div id="hero-nav" class="relative z-10 mt-auto border-t border-white/[0.06] pt-12 flex justify-end opacity-0">
      <a href="/projects" class="group inline-flex items-center gap-3 font-heading text-sm uppercase tracking-wider text-white/50 hover:text-white transition-colors">
        View Projects
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-transform group-hover:translate-x-1">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  import { gsap } from "gsap";

  function initHero() {
    gsap.set(".hero-word", { yPercent: 120 });
    gsap.to(".hero-word", {
      yPercent: 0,
      duration: 1.4,
      ease: "power4.out",
      stagger: 0.2,
      delay: 0.2,
    });

    gsap.to("#hero-label", { opacity: 1, duration: 0.8, delay: 1.0, ease: "power2.out" });
    gsap.to("#hero-desc", { opacity: 1, duration: 0.8, delay: 1.2, ease: "power2.out" });
    gsap.to("#hero-nav", { opacity: 1, duration: 0.8, delay: 1.4, ease: "power2.out" });
  }

  document.addEventListener("astro:page-load", initHero);
</script>
