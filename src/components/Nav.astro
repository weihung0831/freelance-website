---
const links = [
  { href: "/projects/", label: "Projects" },
  { href: "/about/", label: "About" },
  { href: "/contact/", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 z-50 w-full mix-blend-difference" transition:persist>
  <nav class="flex items-center justify-between px-8 sm:px-12 h-20">
    <a href="/" class="flex items-center gap-2.5 font-heading text-sm font-medium text-white tracking-wide uppercase">
      <svg width="20" height="20" viewBox="0 0 64 64" class="shrink-0">
        <rect width="64" height="64" rx="14" fill="currentColor" fill-opacity="0.15"/>
        <path d="M12 18 l8 28 l7 -20 l7 20 l8 -28" fill="none" stroke="url(#nav-g)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
        <defs>
          <linearGradient id="nav-g" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#7c5ce7"/>
            <stop offset="100%" stop-color="#38bdf8"/>
          </linearGradient>
        </defs>
      </svg>
      weihung
    </a>
    <div class="hidden sm:flex items-center gap-10">
      {links.map((link) => (
        <a
          href={link.href}
          class={`font-heading text-sm tracking-wide uppercase transition-opacity ${
            currentPath === link.href ? "text-white" : "text-white/40 hover:text-white"
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
